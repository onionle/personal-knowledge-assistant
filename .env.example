# ========================================================================
# 环境变量模板 —— 复制为 .env 后填入你自己的值（.env 已被 .gitignore 忽略）
#   cp .env.example .env
# 三个实现（Python / LangChain4j / Spring AI）共用这一份。
# ========================================================================

# ---------- 大模型（OpenAI 兼容；默认用 DeepSeek）----------
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx          # 必填，申请：https://platform.deepseek.com
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat                  # 主对话模型（deepseek-chat / deepseek-reasoner 等）

# ---------- 本地 Embedding 模型（Python 版用；不设则联网下载）----------
# 指向已下载好的本地 BGE 目录可离线加载；留空则首次联网从 HuggingFace 下载
# EMBED_MODEL_NAME=/abs/path/to/bge-small-zh-v1.5

# ---------- Chroma 向量库 ----------
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ---------- MySQL（用户系统：登录 / 历史）----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=knowledge_assistant

# ---------- JWT（三个后端共用同一密钥，token 才互认；生产换成长随机串）----------
JWT_SECRET=change-me-to-a-long-random-string

# ---------- 多轮对话带入 LLM 的历史消息条数上限（控制 token）----------
CHAT_HISTORY_MESSAGES=10
